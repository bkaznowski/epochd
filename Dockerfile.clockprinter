FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" -o /clockprinter ./test/targets/clockprinter

FROM scratch
COPY --from=build /clockprinter /clockprinter
ENTRYPOINT ["/clockprinter"]
